PORT=3000
API_PREFIX=api
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bilingual_db?schema=public

# Comma-separated origins allowed by Nest CORS delegate.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# SMTP mail delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Kapter <noreply@example.com>"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace-me

# JWT / auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-second-long-random-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=7
REGISTRATION_TTL_SECONDS=600
REGISTRATION_RESEND_COOLDOWN_SECONDS=60
REGISTRATION_RESEND_MAX_PER_TTL=5
REGISTRATION_RESEND_MAX_PER_IP=10

# MinIO / S3-compatible object storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_PROCESSED=processed
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Kapter Explain provider defaults
AI_EXPLAIN_PROVIDER=openai
AI_EXPLAIN_BASE_URL=https://api.openai.com/v1
AI_EXPLAIN_API_KEY=replace-with-provider-api-key
AI_EXPLAIN_MODEL=gpt-4o-mini
AI_EXPLAIN_PROMPT_VERSION=v3
AI_EXPLAIN_MAX_OUTPUT_TOKENS=800
AI_EXPLAIN_TEMPERATURE=0.2
AI_EXPLAIN_TIMEOUT_MS=30000

# Optional yt-dlp tuning for protected YouTube sessions
YT_DLP_COOKIES_FILE=
YT_DLP_COOKIES_FROM_BROWSER=
YT_DLP_YOUTUBE_EXTRACTOR_ARGS=

# Optional seed overrides used by prisma/seed.ts
SEED_TEST_PASSWORD=Test@123
SEED_ADMIN_EMAIL=admin@kapter.local
SEED_FREE_USER_EMAIL=free.user@kapter.local
SEED_BASIC_MONTHLY_USER_EMAIL=basic.monthly@kapter.local
SEED_BASIC_YEARLY_USER_EMAIL=basic.yearly@kapter.local
SEED_PRO_MONTHLY_USER_EMAIL=pro.monthly@kapter.local
SEED_PRO_YEARLY_USER_EMAIL=pro.yearly@kapter.local
SEED_PRO_LIFETIME_USER_EMAIL=pro.lifetime@kapter.local
