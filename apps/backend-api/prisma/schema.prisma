// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ENUMS
enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum MediaOriginType {
  LOCAL
  YOUTUBE
}

enum MediaStatus {
  QUEUED
  VALIDATING
  PROCESSING
  COMPLETED
  FAILED
}

enum OtpType {
  REGISTER
  FORGOT_PASSWORD
}

enum AiCreditReservationState {
  PENDING
  CONFIRMED
  REFUNDED
}

// --- MODELS ---

model User {
  id            String  @id @default(uuid())
  email         String  @unique
  fullName      String  @map("full_name")
  passwordHash  String  @map("password_hash")
  emailVerified Boolean @default(false) @map("email_verified")

  // Subscription Info
  currentSubscriptionId         String?  @map("current_subscription_id")
  quotaUsageCurrentMonth        Int      @default(0) @map("quota_usage_current_month")
  quotaUsageCurrentMonthSeconds Int      @default(0) @map("quota_usage_current_month_seconds") // Track duration
  lastQuotaResetDate            DateTime @default(now()) @map("last_quota_reset_date")
  aiCreditsRemaining            Int      @default(0) @map("ai_credits_remaining")
  aiCreditsLastResetDate        DateTime @default(now()) @map("ai_credits_last_reset_date")
  role                          Role     @default(USER)

  // Relationships
  currentSubscription  Subscription?         @relation("UserCurrentSub", fields: [currentSubscriptionId], references: [id])
  subscriptions        Subscription[]        @relation("UserHistorySub")
  usageHistories       UsageHistory[]
  mediaItems           MediaItem[]
  vocabularies         UserVocabulary[]
  otps                 Otp[]
  refreshTokens        RefreshToken[]
  chatSessions         ChatSession[]
  chatFeedbacks        ChatFeedback[]
  aiUsageLogs          AiUsageLog[]
  aiCreditReservations AiCreditReservation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model SubscriptionPlan {
  id          String  @id // e.g. "FREE", "PRO_MONTHLY"
  code        String  @unique
  name        String
  description String? @db.Text

  // Marketing & Display
  features  Json?   @map("features") // ["No Ads", "High Quality", "Fast Processing", etc]
  tierLevel Int     @default(1)
  isActive  Boolean @default(true) @map("is_active")

  variants PlanVariant[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscription_plans")
}

model PlanVariant {
  id     String @id @default(uuid())
  planId String @map("plan_id")

  name     String
  price    Decimal @db.Decimal(10, 2)
  currency String  @default("VND")

  billingCycleType BillingCycleType @map("billing_cycle_type")

  // Quota & Limits
  maxDurationPerFile  Int @map("max_duration_per_file") // seconds
  monthlyQuotaSeconds Int @map("monthly_quota_seconds")
  aiCreditsPerMonth   Int @default(0) @map("ai_credits_per_month")

  isActive Boolean @default(true)

  plan          SubscriptionPlan @relation(fields: [planId], references: [id])
  subscriptions Subscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plan_variants")
}

enum BillingCycleType {
  MONTHLY
  SIX_MONTHS
  YEARLY
  LIFETIME
}

model Subscription {
  id     String @id @default(uuid())
  userId String @map("user_id")

  variantId String @map("variant_id")

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  status SubscriptionStatus @default(ACTIVE)

  // Snapshot
  priceSnapshot               Decimal @map("price_snapshot") @db.Decimal(10, 2)
  maxDurationPerFileSnapshot  Int     @map("max_duration_per_file_snapshot")
  monthlyQuotaSecondsSnapshot Int     @map("monthly_quota_seconds_snapshot")
  aiCreditsPerMonthSnapshot   Int     @default(0) @map("ai_credits_per_month_snapshot")

  // Relationships
  user    User        @relation("UserHistorySub", fields: [userId], references: [id])
  users   User[]      @relation("UserCurrentSub")
  variant PlanVariant @relation(fields: [variantId], references: [id])

  usageHistories UsageHistory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model UsageHistory {
  id             String @id @default(uuid())
  userId         String @map("user_id")
  subscriptionId String @map("subscription_id")

  cycleStartDate       DateTime @map("cycle_start_date")
  cycleEndDate         DateTime @map("cycle_end_date")
  totalSecondsUsed     Int      @default(0) @map("total_seconds_used")
  quotaLimitAtThatTime Int      @map("quota_limit_at_that_time") // Snapshot quota

  user         User         @relation(fields: [userId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("usage_histories")
}

model MediaItem {
  id     String @id @default(uuid())
  userId String @map("user_id")

  title      String
  originType MediaOriginType @map("origin_type")
  originUrl  String?         @map("origin_url") // Youtube URL or null if LOCAL

  // Processing Metadata
  sourceLanguage String? @map("source_language") // Auto-detected: "en", "zh", "vi"
  targetLanguage String? @map("target_language") // Requested translation language for downstream explain/prompt context

  // Storage Keys (MinIO/S3 Paths)
  audioS3Key      String  @map("audio_s3_key")
  transcriptS3Key String? @map("transcript_s3_key") // Transcription-only JSON path
  subtitleS3Key   String? @map("subtitle_s3_key") // Translated subtitle JSON path

  durationSeconds        Int         @default(0) @map("duration_seconds")
  status                 MediaStatus @default(QUEUED)
  progress               Float       @default(0) @map("progress") // 0.0 to 1.0
  artifactSummary        Json?       @map("artifact_summary") // Cached artifact availability summary for hot read paths
  currentStep            String?     @map("current_step") // Active pipeline stage: AUDIO_PREP, INSPECTING, VAD, PROCESSING, TRANSLATING, EXPORTING
  estimatedTimeRemaining Int?        @map("estimated_time_remaining") // Seconds remaining (ETA), null when idle/done
  failReason             String?     @map("fail_reason") // Human-readable error

  // Logic flag
  countedInQuota Boolean @default(false) @map("counted_in_quota")

  // Thumbnail / ingestion dataflow
  youtubeVideoId String? @map("youtube_video_id")
  hasThumbnail   Boolean @default(false) @map("has_thumbnail")

  // Relationships
  user                 User                  @relation(fields: [userId], references: [id])
  userVocabularies     UserVocabulary[]
  chatSessions         ChatSession[]
  aiUsageLogs          AiUsageLog[]
  aiCreditReservations AiCreditReservation[]

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at") // Soft delete

  @@map("media_items")
}

model Vocabulary {
  id             String  @id @default(uuid())
  word           String
  normalizedWord String  @map("normalized_word")
  sourceLanguage String  @map("source_language")
  phonetic       String?

  userVocabularies UserVocabulary[]

  @@unique([normalizedWord, sourceLanguage])
  @@index([sourceLanguage])
  @@map("vocabularies")
}

model UserVocabulary {
  id                         String   @id @default(uuid())
  userId                     String   @map("user_id")
  vocabularyId               String   @map("vocabulary_id")
  mediaItemId                String   @map("media_item_id")
  segmentIndex               Int      @map("segment_index")
  startWordIndex             Int      @map("start_word_index")
  endWordIndex               Int      @map("end_word_index")
  selectedTextSnapshot       String   @map("selected_text_snapshot")
  phoneticSnapshot           String   @default("") @map("phonetic_snapshot")
  partOfSpeech               String   @map("part_of_speech")
  contextualDefinition       String   @map("contextual_definition") @db.Text
  sourceSentence             String   @map("source_sentence") @db.Text
  sourceSentenceTranslation  String   @default("") @map("source_sentence_translation") @db.Text
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id])
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id])
  mediaItem  MediaItem  @relation(fields: [mediaItemId], references: [id])

  @@unique([userId, mediaItemId, segmentIndex, startWordIndex, endWordIndex])
  @@index([userId, vocabularyId])
  @@index([mediaItemId, segmentIndex])
  @@map("user_vocabularies")
}

model AiCreditReservation {
  id              String                   @id @default(uuid())
  userId          String                   @map("user_id")
  mediaId         String?                  @map("media_id")
  segmentIndex    Int?                     @map("segment_index")
  state           AiCreditReservationState @default(PENDING)
  creditsReserved Int                      @default(1) @map("credits_reserved")
  requestType     String                   @map("request_type")
  idempotencyKey  String                   @unique @map("idempotency_key")
  confirmedAt     DateTime?                @map("confirmed_at")
  refundedAt      DateTime?                @map("refunded_at")
  expiresAt       DateTime                 @map("expires_at")
  createdAt       DateTime                 @default(now()) @map("created_at")

  user      User          @relation(fields: [userId], references: [id])
  mediaItem MediaItem?    @relation(fields: [mediaId], references: [id])
  usageLog  AiUsageLog?

  @@index([userId, state])
  @@index([expiresAt, state])
  @@index([mediaId, segmentIndex])
  @@map("ai_credit_reservations")
}

model AiUsageLog {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  mediaId         String   @map("media_id")
  segmentIndex    Int      @map("segment_index")
  segmentText     String?  @map("segment_text") @db.Text
  requestType     String   @map("request_type")
  reservationId   String?  @unique @map("reservation_id")
  creditsConsumed Int      @default(1) @map("credits_consumed")
  tokensInput     Int      @default(0) @map("tokens_input")
  tokensOutput    Int      @default(0) @map("tokens_output")
  modelUsed       String   @map("model_used")
  provider        String   @default("openai")
  promptVersion   String   @map("prompt_version")
  latencyMs       Int      @default(0) @map("latency_ms")
  cacheHit        Boolean  @default(false) @map("cache_hit")
  rejected        Boolean  @default(false)
  aborted         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  user        User                 @relation(fields: [userId], references: [id])
  mediaItem   MediaItem            @relation(fields: [mediaId], references: [id])
  reservation AiCreditReservation? @relation(fields: [reservationId], references: [id])

  @@index([userId])
  @@index([mediaId, segmentIndex])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

model ChatSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  mediaId      String   @map("media_id")
  segmentIndex Int      @map("segment_index")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user      User          @relation(fields: [userId], references: [id])
  mediaItem MediaItem     @relation(fields: [mediaId], references: [id])
  messages  ChatMessage[]

  @@unique([userId, mediaId, segmentIndex])
  @@index([userId])
  @@index([mediaId])
  @@map("chat_sessions")
}

model ChatMessage {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  role       String
  content    String   @db.Text
  tokensUsed Int      @default(0) @map("tokens_used")
  createdAt  DateTime @default(now()) @map("created_at")

  session  ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  feedback ChatFeedback?

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model ChatFeedback {
  id        String   @id @default(uuid())
  messageId String   @unique @map("message_id")
  userId    String   @map("user_id")
  rating    String
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("chat_feedbacks")
}

model Otp {
  id     String  @id @default(uuid())
  email  String // Always required for email delivery
  userId String? @map("user_id") // Optional - null for REGISTER, set for FORGOT_PASSWORD
  code   String // 6-digit OTP code
  type   OtpType

  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([email, type])
  @@index([userId, type])
  @@map("otps")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String   @map("user_id")
  deviceInfo String?  @map("device_info") // User Agent
  ip         String? // Client IP address
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
